{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/.well-known/:path*", "destination": "/.well-known/:path*" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/(.*)",
      "destination": "/api/og/$1",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i)(WhatsApp|Telegram|facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|Discordbot|Google-Read-Aloud|bingbot|Googlebot|GoogleOther|Google-InspectionTool|Storebot-Google|AdsBot-Google|Mediapartners-Google|Pinterest|vkShare|Applebot|DuckDuckBot|Baiduspider|YandexBot)"
        }
      ]
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
